{
  "name": "medusa-starter-default",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:dev": "medusa exec ./src/scripts/seed.dev.ts",
    "email:test": "medusa exec ./src/scripts/send-brevo-test.ts",
    "stress-test": "medusa exec ./src/scripts/stress-test-products.ts",
    "stress-test:full": "sh ./scripts/run-stress-test.sh",
    "stress-test:monitor": "sh ./scripts/monitor-stress-test.sh 1800",
    "stress-test:tx": "bash ./scripts/run-transaction-stress.sh",
    "stress-test:tx:20": "STRESS_CONCURRENCY=20 STRESS_DURATION_SECONDS=900 bash ./scripts/run-transaction-stress.sh",
    "stress-test:tx:50": "STRESS_CONCURRENCY=50 STRESS_DURATION_SECONDS=900 bash ./scripts/run-transaction-stress.sh",
    "stress-test:tx:100": "STRESS_CONCURRENCY=100 STRESS_DURATION_SECONDS=600 bash ./scripts/run-transaction-stress.sh",
    "stress-test:tx:recovery": "bash ./scripts/run-transaction-recovery-drill.sh",
    "stress-test:soak": "bash ./scripts/run-soak-capacity-test.sh",
    "stress-test:soak:6h": "SOAK_DURATION_SECONDS=21600 bash ./scripts/run-soak-capacity-test.sh",
    "stress-test:soak:24h": "SOAK_DURATION_SECONDS=86400 bash ./scripts/run-soak-capacity-test.sh",
    "stress-test:1gb-break": "bash ./scripts/run-1gb-break-test.sh",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:custom-orders": "yarn test:integration:http integration-tests/http/custom-orders.spec.ts",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "docker:up": "sh ./scripts/docker-up-prebuilt.sh",
    "docker:down": "docker compose down",
    "docker:dev:up": "sh ./scripts/docker-up-dev.sh",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.14.2",
    "@medusajs/cli": "2.14.2",
    "@medusajs/framework": "2.14.2",
    "@medusajs/medusa": "2.14.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.4",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^30.3.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
